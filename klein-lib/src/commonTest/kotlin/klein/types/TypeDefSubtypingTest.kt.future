    @Test
    fun constructorSubtypesOwnType() {
        val sub = subtype()
        val consNum1 = tref(
            name = "Cons",
            typeArgs = listOf(SimpleType.TNum),
            structure = SimpleType.TRecord(mapOf("head" to SimpleType.TNum)),
            parentName = "List",
            parentVariance = listOf(Variance.Covariant),
        )
        val consNum2 = tref(
            name = "Cons",
            typeArgs = listOf(SimpleType.TNum),
            structure = SimpleType.TRecord(mapOf("head" to SimpleType.TNum)),
            parentName = "List",
            parentVariance = listOf(Variance.Covariant),
        )
        sub.constrain(consNum1, consNum2, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
