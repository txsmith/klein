    @Test
    fun bareConstructorSubtypesParent_anyConcreteType() {
        val sub = subtype()
        val nilType = tref(
            name = "Nil",
            typeArgs = emptyList(),
            structure = SimpleType.TRecord(emptyMap()),
            parentName = "List",
            parentVariance = listOf(Variance.Covariant),
