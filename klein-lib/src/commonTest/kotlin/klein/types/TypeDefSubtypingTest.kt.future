    // =========================================================================
    // Edge cases and combinations
    // =========================================================================

    @Test
    fun nominalTypeInFunctionResult_covariant() {
        val sub = subtype()
        val dog = tref("Dog", emptyList(), SimpleType.TRecord(emptyMap()))
        val animal = tref("Animal", emptyList(), SimpleType.TRecord(emptyMap()))
        sub.constrain(dog, animal, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
        val listDog = tref(
            name = "List",
            typeArgs = listOf(dog),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        val listAnimal = tref(
            name = "List",
            typeArgs = listOf(animal),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        val producerDog = SimpleType.TFun(emptyList(), listDog)
        val producerAnimal = SimpleType.TFun(emptyList(), listAnimal)
        val sub2 = subtype()
        sub2.constrain(dog, animal, SourceSpan.zero)
        sub2.constrain(producerDog, producerAnimal, SourceSpan.zero)
        assertTrue(sub2.getErrors().isEmpty())
    }

    @Test
    fun nominalTypeInFunctionParam_contravariant() {
        val sub = subtype()
        val dog = tref("Dog", emptyList(), SimpleType.TRecord(emptyMap()))
        val animal = tref("Animal", emptyList(), SimpleType.TRecord(emptyMap()))
        sub.constrain(dog, animal, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
        val listDog = tref(
            name = "List",
            typeArgs = listOf(dog),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        val listAnimal = tref(
            name = "List",
            typeArgs = listOf(animal),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        val consumerAnimal = SimpleType.TFun(listOf(listAnimal), SimpleType.TUnit)
        val consumerDog = SimpleType.TFun(listOf(listDog), SimpleType.TUnit)
        val sub2 = subtype()
        sub2.constrain(dog, animal, SourceSpan.zero)
        sub2.constrain(consumerAnimal, consumerDog, SourceSpan.zero)
        assertTrue(sub2.getErrors().isEmpty())
    }

    @Test
    fun nominalTypeInRecordField() {
        val sub = subtype()
        val moneyType = tref(
            name = "Money",
            typeArgs = emptyList(),
            structure = SimpleType.TRecord(mapOf("value" to SimpleType.TNum)),
        )
        val accountWithMoney = SimpleType.TRecord(mapOf("balance" to moneyType))
        val accountWithNum = SimpleType.TRecord(mapOf("balance" to moneyType))
        sub.constrain(accountWithMoney, accountWithNum, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
    }

    @Test
    fun nestedNominalTypes() {
        val sub = subtype()
        val innerList = tref(
            name = "List",
            typeArgs = listOf(SimpleType.TNum),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        val outerList1 = tref(
            name = "List",
            typeArgs = listOf(innerList),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        val outerList2 = tref(
            name = "List",
            typeArgs = listOf(innerList),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        sub.constrain(outerList1, outerList2, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
    }

    @Test
    fun nominalTypeWithTypeVarArg() {
        val sub = subtype()
        val v = tvar()
        val listV = tref(
            name = "List",
            typeArgs = listOf(v),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        val listNum = tref(
            name = "List",
            typeArgs = listOf(SimpleType.TNum),
            structure = SimpleType.TRecord(emptyMap()),
            variance = listOf(Variance.Covariant),
        )
        sub.constrain(listV, listNum, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
        assertTrue(SimpleType.TNum in v.upperBounds)
    }

    @Test
    fun nominalSubtypeOfItself() {
        val sub = subtype()
        val money = tref(
            name = "Money",
            typeArgs = emptyList(),
            structure = SimpleType.TRecord(mapOf("value" to SimpleType.TNum)),
        )
        sub.constrain(money, money, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
    }

    @Test
    fun constructorCanAccessParentInterface() {
        val sub = subtype()
        val someValue = tref(
            name = "Some",
            typeArgs = listOf(SimpleType.TNum),
            structure = SimpleType.TRecord(mapOf("value" to SimpleType.TNum)),
            parentName = "Option",
            parentVariance = listOf(Variance.Covariant),
        )
        val recordWithValue = SimpleType.TRecord(mapOf("value" to SimpleType.TNum))
        sub.constrain(someValue, recordWithValue, SourceSpan.zero)
        assertTrue(sub.getErrors().isEmpty())
    }

    @Test
    fun nominalNotSubtypeOfPrimitive() {
        val sub = subtype()
        val money = tref(
            name = "Money",
            typeArgs = emptyList(),
            structure = SimpleType.TRecord(mapOf("value" to SimpleType.TNum)),
        )
        sub.constrain(money, SimpleType.TNum, SourceSpan.zero)
        assertEquals(1, sub.getErrors().size)
        assertTrue(sub.getErrors()[0] is TypeError.TypeMismatch)
    }

    @Test
    fun primitiveNotSubtypeOfNominal() {
        val sub = subtype()
        val money = tref(
            name = "Money",
            typeArgs = emptyList(),
            structure = SimpleType.TRecord(mapOf("value" to SimpleType.TNum)),
        )
        sub.constrain(SimpleType.TNum, money, SourceSpan.zero)
        assertEquals(1, sub.getErrors().size)
        assertTrue(sub.getErrors()[0] is TypeError.TypeMismatch)
    }

    @Test
    fun nominalNotSubtypeOfFunction() {
        val sub = subtype()
        val money = tref(
            name = "Money",
            typeArgs = emptyList(),
            structure = SimpleType.TRecord(mapOf("value" to SimpleType.TNum)),
        )
        val func = SimpleType.TFun(listOf(SimpleType.TNum), SimpleType.TNum)
        sub.constrain(money, func, SourceSpan.zero)
        assertEquals(1, sub.getErrors().size)
        assertTrue(sub.getErrors()[0] is TypeError.TypeMismatch)
    }

    @Test
    fun functionNotSubtypeOfNominal() {
        val sub = subtype()
        val money = tref(
            name = "Money",
            typeArgs = emptyList(),
            structure = SimpleType.TRecord(mapOf("value" to SimpleType.TNum)),
        )
        val func = SimpleType.TFun(listOf(SimpleType.TNum), SimpleType.TNum)
        sub.constrain(func, money, SourceSpan.zero)
        assertEquals(1, sub.getErrors().size)
        assertTrue(sub.getErrors()[0] is TypeError.TypeMismatch)
    }

    private fun tref(
        name: String,
        typeArgs: List<SimpleType>,
        structure: SimpleType,
        variance: List<Variance> = emptyList(),
        parentName: String? = null,
        parentVariance: List<Variance> = emptyList(),
    ): SimpleType.TRef = SimpleType.TRef(
        name = name,
        typeArgs = typeArgs,
        structure = structure,
        variance = variance,
        parentName = parentName,
        parentVariance = parentVariance,
        span = SourceSpan.zero,
    )
}
